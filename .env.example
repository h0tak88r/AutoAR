# AutoAR — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.

# ─── Mode ────────────────────────────────────────────────────────────────────
AUTOAR_MODE=api          # api | discord | both

# ─── Database ────────────────────────────────────────────────────────────────
DB_TYPE=postgresql        # postgresql | sqlite
DB_HOST=postgresql://autoar:password@localhost:5432/bughunt?sslmode=disable
# DB_TYPE=sqlite
# DB_HOST=/data/autoar.db

# ─── Dashboard Auth ──────────────────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme
AUTOAR_JWT_SECRET=your-secret-here

# ─── Supabase (optional, for managed auth) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_ONLY=false
DISCORD_ALLOWED_GUILD=

# ─── Bug Bounty Platform Credentials ─────────────────────────────────────────
# HackerOne
H1_USERNAME=
H1_TOKEN=

# Bugcrowd
BUGCROWD_TOKEN=

# YesWeHack (JWT token — no email/password needed)
YWH_TOKEN=

# Intigriti
INTIGRITI_TOKEN=

# Immunefi — no credentials required

# ─── Recon API Keys (all optional but improve coverage) ──────────────────────
GITHUB_TOKEN=
SECURITYTRAILS_API_KEY=
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
CERTSPOTTER_API_KEY=
CHAOS_API_KEY=
FOFA_EMAIL=
FOFA_KEY=
WHOISXMLAPI_API_KEY=
ZOOMEYE_USERNAME=
ZOOMEYE_PASSWORD=
ZOOMEYEAPI_API_KEY=
URLSCAN_API_KEY=
BEVIGIL_API_KEY=
BINARYEDGE_API_KEY=
WORDPRESS_API_KEY=

# ─── AI / OpenRouter ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── Nuclei ──────────────────────────────────────────────────────────────────
NUCLEI_TEMPLATES_PATH=./nuclei-templates
NUCLEI_RATE_LIMIT=150
NUCLEI_CONCURRENCY=25

# ─── FFUF ────────────────────────────────────────────────────────────────────
FFUF_WORDLIST_PATH=./Wordlists/fuzz.txt
FFUF_THREADS=50

# ─── Subfinder ───────────────────────────────────────────────────────────────
SUBFINDER_THREADS=10

# ─── GitHub Recon ────────────────────────────────────────────────────────────
GITHUB_MAX_REPOS=500
GITHUB_PARALLEL_JOBS=5
GITHUB_HTML_REPORTS=false
GITHUB_SCAN_TYPES=secrets,dependencies

# ─── Storage / Results ───────────────────────────────────────────────────────
AUTOAR_RESULTS_DIR=./new-results
AUTOAR_CONFIG_FILE=
AUTOAR_SCRIPT_PATH=

# ─── Cloudflare R2 (optional artifact storage) ───────────────────────────────
USE_R2_STORAGE=false
R2_BUCKET_NAME=autoar
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_KEY=

# ─── Mobile / APK ────────────────────────────────────────────────────────────
APKX_WORKERS=4
APKX_MAX_FILES=50
IPATOOL_EMAIL=
IPATOOL_PASSWORD=
IPATOOL_AUTH_CODE=
IPATOOL_KEYCHAIN_PASSPHRASE=
